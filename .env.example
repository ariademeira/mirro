# Supabase
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Sonnet API (backend only — never expose to client)
# Used in Supabase Edge Functions, not in Vite frontend
ANTHROPIC_API_KEY=sk-ant-...

# ── Phase 1 feature flags (change without redeploying) ──────────────────────

# Insight display format: three-layer | insight-only | suggestion-only
VITE_INSIGHT_FORMAT=three-layer

# Framing language (A/B testable)
VITE_FRAMING_COLLEAGUE_NOTES=Personal Observations
VITE_FRAMING_USER_INSIGHTS=Patterns
VITE_FRAMING_IMPROVEMENTS=Growth Edges

# Free tier limits
VITE_FREE_COLLEAGUES=5
VITE_FREE_INTERACTIONS=50
VITE_FREE_INSIGHTS=5
VITE_FREE_HISTORY_DAYS=7

# Sonnet system prompt version (filename in /prompts/ without .txt)
VITE_SONNET_PROMPT_VERSION=v1_empowering

# HITL confidence threshold (0.0 - 1.0)
VITE_HITL_THRESHOLD=0.7

# Stripe (Phase 2 — leave empty for MVP)
VITE_STRIPE_PUBLIC_KEY=
